# ============================================================
# LeetCode Coach — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# ============================================================

# ── Anthropic (Claude AI) ───────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Notion ──────────────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations
# 2. Click "+ New integration", give it a name, select your workspace
# 3. Copy the "Internal Integration Secret"
NOTION_API_KEY=secret_...

# 4. Open your Notion database page
# 5. Click "Share" → "Invite" → select your integration
# 6. Copy the database ID from the URL:
#    https://notion.so/myworkspace/{DATABASE_ID}?v=...
#    (the part between the last / and the ?)
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Optional Settings ────────────────────────────────────────
# AI model to use. Options:
#   claude-haiku-4-5-20251001  (fast, cheap — default)
#   claude-sonnet-4-6          (smarter, more expensive)
AI_MODEL=claude-haiku-4-5-20251001
