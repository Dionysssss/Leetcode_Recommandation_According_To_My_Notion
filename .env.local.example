# ============================================================
# LeetCode Coach — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# ============================================================

# ── Anthropic (Claude AI) ───────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Notion OAuth (recommended) ──────────────────────────────
# 1. Go to https://www.notion.so/my-integrations → your integration
# 2. Under "OAuth Domain & URIs", copy the Client ID and Secret
NOTION_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_CLIENT_SECRET=secret_...
# Must match exactly what you set in the Notion integration settings
NOTION_REDIRECT_URI=https://leetcode-recommendation.vercel.app/api/auth/callback/notion
# For local dev, also add: http://localhost:3000/api/auth/callback/notion

# ── Notion Internal Token (optional fallback) ────────────────
# If not using OAuth, you can set these env vars to skip the UI login step
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Optional Settings ────────────────────────────────────────
# AI model to use. Options:
#   claude-haiku-4-5-20251001  (fast, cheap — default)
#   claude-sonnet-4-6          (smarter, more expensive)
AI_MODEL=claude-haiku-4-5-20251001
